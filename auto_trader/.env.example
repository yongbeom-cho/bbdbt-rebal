# Copy to .env and fill in values:
#   cp .env.example .env
#
# Used by auto_trade.py (load_dotenv). Secrets stay in .env only — never commit .env.

# ── 한국투자증권 Open API (필수) ─────────────────────────────────────────────
app_key=
app_secret=
# 계좌번호 8자리-2자리 (예: 12345678-01)
acc_no=

# 실전 API URL (선택, 비우면 koreainvestment 기본값 사용)
# api_url=https://openapi.koreainvestment.com:9443

# ── Discord 알림 (선택) ─────────────────────────────────────────────────────
# webhook URL — 체결/경고/스킵 알림
discord_url=

# config에 discord_webhook_env 를 바꾼 경우 해당 변수명 사용 (기본: DISCORD_WEBHOOK_URL)
# DISCORD_WEBHOOK_URL=
